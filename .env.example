NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: transactional email via Resend (https://resend.com)
# Without these, in-app notifications still fire — only emails are skipped.
RESEND_API_KEY=
RESEND_FROM="BIZI <onboarding@resend.dev>"

# Required for the daily inactivity cron (see vercel.json). Vercel injects
# this as `Authorization: Bearer <CRON_SECRET>` when invoking the route.
# Generate with: `openssl rand -hex 32` (or any random 32+ char string).
CRON_SECRET=

# Internal admin API for seeding mock accounts (see scripts/seed-accounts.ts).
# Generate with: openssl rand -hex 32
ADMIN_SECRET=

# Stripe — payment processing for Creator Pro / Creator Elite subscriptions
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Stripe Price IDs (create in Stripe dashboard under Products)
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=

# Rate limiting via Upstash Redis (https://upstash.com — free tier)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
